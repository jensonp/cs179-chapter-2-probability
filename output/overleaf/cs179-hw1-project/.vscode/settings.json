{
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 250,
  "task.allowAutomaticTasks": "on",
  "editor.semanticHighlighting.enabled": true,
  "obsidianLatexSuite.obsidianDataJsonPath": "/Users/jensonphan/Desktop/Reference/UCI Upper Division Notes/.obsidian/plugins/obsidian-latex-suite/data.json",
  "obsidianLatexSuite.toml.targetFiles": [
    "answers.toml"
  ],
  "files.associations": {
    "*.toml": "toml",
    "answers.toml": "toml"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment.line.number-sign.toml",
        "settings": {
          "foreground": "#6A9955",
          "fontStyle": "italic"
        }
      },
      {
        "scope": "support.type.property-name.toml",
        "settings": {
          "foreground": "#4FC1FF"
        }
      },
      {
        "scope": "string.quoted.single.toml",
        "settings": {
          "foreground": "#CE9178"
        }
      },
      {
        "scope": "constant.language.boolean.toml",
        "settings": {
          "foreground": "#569CD6"
        }
      },
      {
        "scope": "constant.numeric.toml",
        "settings": {
          "foreground": "#B5CEA8"
        }
      }
    ]
  },
  "workbench.editorAssociations": {
    "*.pdf": "latex-workshop-pdf-hook",
    "*.PDF": "latex-workshop-pdf-hook"
  },
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.outDir": "../build",
  "latex-workshop.latex.recipes": [
    {
      "name": "hw1-live-preview",
      "tools": [
        "hw1-build-helper"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "hw1-build-helper",
      "command": "/Library/Developer/CommandLineTools/usr/bin/python3",
      "args": [
        "%DIR%/../.vscode/build_hw1.py",
        "%DIR%/main.tex"
      ],
      "env": {}
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.view.pdf.tab.editorGroup": "right",
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
  "[latex]": {
    "editor.wordWrap": "on",
    "editor.tabCompletion": "onlySnippets",
    "editor.snippetSuggestions": "top",
    "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\\\|;:'\\\",.<>/?"
  },
  "[toml]": {
    "editor.wordWrap": "on",
    "editor.semanticHighlighting.enabled": true
  }
}
